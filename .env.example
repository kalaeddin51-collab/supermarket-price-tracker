# Copy this to .env and fill in your values

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a long random string: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:
DATABASE_URL=sqlite:///./prices.db
# Production (Neon free PostgreSQL — paste your Neon connection string here):
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Email (Resend - https://resend.com) ───────────────────────────────────────
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=prices@yourdomain.com
EMAIL_TO=you@youremail.com

# ── Push notifications (ntfy.sh - https://ntfy.sh) ───────────────────────────
# Create a topic at ntfy.sh and put the topic name here
NTFY_TOPIC=your-secret-topic-name

# ── Store IDs ─────────────────────────────────────────────────────────────────
# Woolworths store IDs (find by visiting woolworths.com.au and checking requests)
WOOLWORTHS_STORE_ID=3055

# Coles store IDs
COLES_STORE_ID=1234

# ── Scraper settings ──────────────────────────────────────────────────────────
SCRAPE_DELAY_SECONDS=3
REQUEST_TIMEOUT_SECONDS=30

# ── Proxy for Woolworths/Coles (their anti-bot blocks cloud IPs) ─────
# Sign up for a residential proxy service (ScraperAPI, Bright Data, SmartProxy)
# ScraperAPI example: http://scraperapi:YOUR_KEY@proxy-server.scraperapi.com:8001
SCRAPER_PROXY=
